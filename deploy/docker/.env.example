# Copy to .env and edit. docker-compose reads this file.

# ---------------------------------------------------------------------------
# DotCraft AppServer
# ---------------------------------------------------------------------------
# Shared bearer token for the AppServer. REQUIRED because the AppServer binds a
# non-loopback address inside the compose network. Generate a strong value, e.g.:
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
APPSERVER_TOKEN=
APPSERVER_PORT=9100
DASHBOARD_PORT=8080

# Only publish AppServer/Dashboard on loopback. Reach them over SSH tunnels.
APPSERVER_PUBLISH_HOST=127.0.0.1
DASHBOARD_PUBLISH_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# LLM provider for DotCraft agents (consumed by the dotcraft image)
# ---------------------------------------------------------------------------
DOTCRAFT_PROVIDER=anthropic
DOTCRAFT_MODEL=claude-opus-4-8
DOTCRAFT_API_KEY=

# ---------------------------------------------------------------------------
# Shared workspace (host directory bind-mounted into BOTH containers at /workspace)
# Clone each dispatchable repo into <this dir>/<repo> before first dispatch.
# ---------------------------------------------------------------------------
ORATORIO_WORKSPACE_DIR=./workspace

# ---------------------------------------------------------------------------
# Oratorio backend
# ---------------------------------------------------------------------------
ORATORIO_PORT=5087
ORATORIO_PUBLISH_HOST=127.0.0.1

# Repository -> workspace routing for run dispatch (required for every repo you
# dispatch). Project is a source key; WorkspacePath is the checkout under /workspace.
# Example: a repo cloned to ./workspace/myrepo, tracked as github:owner/myrepo.
ORATORIO_REPO0_PROJECT=github:owner/myrepo
ORATORIO_REPO0_WORKSPACE=/workspace/myrepo

# ---------------------------------------------------------------------------
# GitHub source sync (GitHub App; leave blank to skip)
# ---------------------------------------------------------------------------
ORATORIO_GITHUB_REPO0=owner/myrepo
ORATORIO_GITHUB_APP_ID=
ORATORIO_GITHUB_PRIVATE_KEY_PATH=/secrets/github-app.pem
ORATORIO_GITHUB_WRITES=true
