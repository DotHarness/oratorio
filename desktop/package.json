{
  "name": "oratorio-desktop",
  "version": "0.1.7",
  "description": "Oratorio Desktop",
  "author": {
    "name": "Oratorio"
  },
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:mcp-apps && tsc -b && electron-vite build",
    "build:mcp-apps": "vite build --config mcp-apps/vite.config.ts --mode board && vite build --config mcp-apps/vite.config.ts --mode item && vite build --config mcp-apps/vite.config.ts --mode review",
    "preview": "electron-vite preview",
    "test": "vitest run --pool=forks",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "jsdom": "^26.1.0",
    "typescript": "~6.0.2",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^5.0.0",
    "global-agent": "^4.1.3"
  },
  "build": {
    "appId": "com.oratorio.desktop",
    "productName": "Oratorio",
    "protocols": [
      {
        "name": "Oratorio App Binding",
        "schemes": [
          "oratorio"
        ]
      }
    ],
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "asar": true,
      "icon": "resources/icon.ico",
      "executableName": "Oratorio",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    }
  }
}
