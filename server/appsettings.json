{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Oratorio.Server": "Information"
    }
  },
  "AllowedHosts": "*",
  "Oratorio": {
    "SeedData": false,
    "GitHub": {
      "Endpoint": "https://api.github.com",
      "WritesEnabled": false,
      "Repositories": []
    },
    "DotCraft": {
      "RepositoryWorkspaces": {},
      "AppServerUrl": "ws://127.0.0.1:9100/ws",
      "AutoStart": false,
      "RunTimeoutSeconds": 1800,
      "ApprovalPolicy": "interrupt"
    },
    "Automation": {
      "AutoDispatchEnabled": false,
      "AutoDispatchAllowLabels": [ "oratorio:auto" ],
      "AutoDispatchBlockLabels": [ "blocked", "on hold", "needs-design", "needs-human" ],
      "DeliveryPolicy": "ManualDelivery",
      "MaxImplementationTurns": 3,
      "AutoReviewRepositories": [],
      "AutoReviewPublishEnabled": false,
      "AutoReviewPublishRepositories": []
    }
  }
}
